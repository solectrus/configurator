---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { Locale } from '@/i18n/content';
import { content } from '@/i18n/content';
import Bleed from '@/components/Bleed.astro';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = content[lang];

// Real screenshots live in src/assets/screenshots/<lang>/ as PNG. Astro picks
// the target formats itself (AVIF/WebP/JPEG) and fingerprints the output.
// Files are matched by their numeric filename prefix, so the order (1-…, 2-…,
// 3-…) lines up with t.screenshots.items.
const modules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/screenshots/**/*.{png,jpg,jpeg,webp,avif}',
  { eager: true },
);

const sources: ImageMetadata[] = Object.entries(modules)
  .filter(([path]) => path.includes(`/screenshots/${lang}/`))
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([, mod]) => mod.default);

// Pre-generate a small thumbnail (3 formats) and a large image for the zoomed
// lightbox view. PhotoSwipe needs the full image dimensions on the link.
const items = await Promise.all(
  t.screenshots.items.map(async (shot, index) => {
    const image = sources[index];
    if (!image) return { shot, image: null } as const;

    const [avif, webp, jpeg, full] = await Promise.all([
      getImage({ src: image, width: 900, quality: 55, format: 'avif' }),
      getImage({ src: image, width: 900, quality: 60, format: 'webp' }),
      getImage({ src: image, width: 900, quality: 65, format: 'jpeg' }),
      getImage({ src: image, width: 2560, quality: 80, format: 'webp' }),
    ]);

    return { shot, image, avif, webp, jpeg, full } as const;
  }),
);
---

<section class="mt-32">
  <Bleed inner="max-w-7xl">
    <h2 class="section-heading text-center">
      {t.screenshots.heading}
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-center text-lg text-indigo-200">
      {t.screenshots.lead}
    </p>

    <div class="pswp-gallery mt-10 grid gap-8 sm:grid-cols-3">
      {
        items.map((item, index) =>
          item.image ? (
            <figure class="group flex flex-col">
              <a
                href={item.full.src}
                data-pswp-width={item.full.attributes.width}
                data-pswp-height={item.full.attributes.height}
                target="_blank"
                rel="noopener"
                aria-label={`${item.shot.alt} – ${t.ui.enlarge}`}
                class="focus-ring block cursor-zoom-in overflow-hidden rounded-xl"
              >
                <picture>
                  <source type="image/avif" srcset={item.avif.src} />
                  <source type="image/webp" srcset={item.webp.src} />
                  <img
                    src={item.jpeg.src}
                    alt={item.shot.alt}
                    width={item.jpeg.attributes.width}
                    height={item.jpeg.attributes.height}
                    loading={index === 0 ? 'eager' : 'lazy'}
                    decoding="async"
                    class="h-auto w-full transition-transform duration-300 ease-out group-hover:scale-105"
                  />
                </picture>
              </a>
              <figcaption class="px-5 py-4 text-center font-medium tracking-wide text-indigo-200">
                {item.shot.caption}
              </figcaption>
            </figure>
          ) : (
            <figure class="flex flex-col">
              <div class="flex aspect-[16/10] w-full items-center justify-center rounded-xl bg-indigo-950/40 text-indigo-400">
                {item.shot.caption}
              </div>
            </figure>
          ),
        )
      }
    </div>
  </Bleed>
</section>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  const lightbox = new PhotoSwipeLightbox({
    gallery: '.pswp-gallery',
    children: 'a',
    pswpModule: () => import('photoswipe'),
  });

  lightbox.init();
</script>

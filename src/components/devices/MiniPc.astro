---
// Mini-PC — low, wide box with power ring, front ports and feet
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<svg viewBox="0 0 64 64" class={className} aria-hidden="true">
  <rect
    x="9"
    y="24"
    width="46"
    height="20"
    rx="4"
    class="fill-indigo-900 stroke-indigo-500"
    stroke-width="2"
  >
  </rect>
  <circle
    cx="46"
    cy="34"
    r="3.4"
    class="fill-none stroke-indigo-400"
    stroke-width="1.6"
  >
  </circle>
  <path
    d="M46 31.5v3.2"
    class="stroke-pink-500"
    stroke-width="1.6"
    stroke-linecap="round"
  >
  </path>
  <rect x="15" y="32" width="6" height="3.6" rx="1" class="fill-indigo-700">
  </rect>
  <rect x="23" y="32" width="6" height="3.6" rx="1" class="fill-indigo-700">
  </rect>
  <circle cx="34" cy="33.8" r="1.2" class="fill-emerald-400"></circle>
  <path
    d="M16 44v3.5M48 44v3.5"
    class="stroke-indigo-600"
    stroke-width="2.5"
    stroke-linecap="round"
  >
  </path>
</svg>

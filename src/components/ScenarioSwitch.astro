---
import type { Locale } from '@/i18n/content';
import { content, commands } from '@/i18n/content';
import CodeBlock from '@/components/CodeBlock.astro';
import { Icon } from 'astro-icon/components';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = content[lang];

const scenarios = [
  {
    id: 'fresh',
    label: t.install.scenarios.fresh.label,
    desc: t.install.scenarios.fresh.desc,
    hint: t.install.scenarios.fresh.hint,
    command: commands.fresh,
    // Sparkles — a clean, brand-new setup
    icon: 'tabler:sparkles',
  },
  {
    id: 'existing',
    label: t.install.scenarios.existing.label,
    desc: t.install.scenarios.existing.desc,
    hint: t.install.scenarios.existing.hint,
    command: t.install.scenarios.existing.command,
    // Refresh — modernize what is already there
    icon: 'tabler:refresh',
  },
] as const;
---

<div data-scenario-switch>
  <fieldset>
    <legend class="sr-only">{t.install.scenarioLegend}</legend>

    {/* Selectable cards — the active card is driven purely by CSS (:has) */}
    <div role="radiogroup" class="grid gap-3 sm:grid-cols-2">
      {
        scenarios.map((scenario, index) => (
          <label class="group relative block cursor-pointer">
            <input
              type="radio"
              name="scenario"
              value={scenario.id}
              class="peer sr-only"
              checked={index === 0}
              data-scenario-radio
            />

            <div class="flex h-full items-start gap-4 rounded-2xl border border-indigo-700/50 bg-indigo-900/40 p-5 transition-colors duration-200 group-hover:border-indigo-500 group-has-[:checked]:border-pink-500 group-has-[:checked]:bg-pink-600 group-has-[:checked]:shadow-lg group-has-[:checked]:shadow-pink-900/40 group-has-[:focus-visible]:ring-2 group-has-[:focus-visible]:ring-pink-400 group-has-[:focus-visible]:ring-offset-2 group-has-[:focus-visible]:ring-offset-indigo-900">
              <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-indigo-800/60 text-indigo-300 transition-colors duration-200 group-has-[:checked]:bg-white/20 group-has-[:checked]:text-white">
                <Icon name={scenario.icon} class="h-6 w-6" aria-hidden="true" />
              </span>

              <div class="min-w-0 pr-7">
                <span class="block font-semibold text-indigo-100 transition-colors duration-200 group-has-[:checked]:text-white">
                  {scenario.label}
                </span>
                <span class="mt-1 block text-indigo-300 transition-colors duration-200 group-has-[:checked]:text-pink-100">
                  {scenario.desc}
                </span>
              </div>

              {/* Check badge — fades in on the selected card */}
              <span
                aria-hidden="true"
                class="absolute top-4 right-4 flex h-6 w-6 scale-75 items-center justify-center rounded-full bg-white text-pink-600 opacity-0 transition-all duration-200 group-has-[:checked]:scale-100 group-has-[:checked]:opacity-100"
              >
                <Icon name="tabler:check" class="h-4 w-4" aria-hidden="true" />
              </span>
            </div>
          </label>
        ))
      }
    </div>
  </fieldset>

  <div class="mt-8 space-y-3">
    {
      scenarios.map((scenario, index) => (
        <div
          data-scenario-panel={scenario.id}
          class="space-y-3"
          hidden={index !== 0}
        >
          <p class="text-indigo-300">{scenario.hint}</p>
          <CodeBlock code={scenario.command} copy={false} step={1} {lang} />
        </div>
      ))
    }
  </div>
</div>

<script>
  function initScenarioSwitch() {
    document
      .querySelectorAll<HTMLElement>('[data-scenario-switch]')
      .forEach((root) => {
        const radios = Array.from(
          root.querySelectorAll<HTMLInputElement>('[data-scenario-radio]'),
        );
        const panels = Array.from(
          root.querySelectorAll<HTMLElement>('[data-scenario-panel]'),
        );

        const update = (animate: boolean) => {
          const selected = radios.find((radio) => radio.checked)?.value;

          panels.forEach((panel) => {
            const active = panel.dataset.scenarioPanel === selected;
            panel.hidden = !active;
            panel.classList.remove('animate-fade-in');
            if (active && animate) {
              // Force reflow so the animation restarts on every switch
              void panel.offsetWidth;
              panel.classList.add('animate-fade-in');
            }
          });
        };

        radios.forEach((radio) =>
          radio.addEventListener('change', () => update(true)),
        );
        update(false);
      });
  }

  initScenarioSwitch();
</script>

{
  "$schema": "https://json.schemastore.org/prettierrc",
  "plugins": ["prettier-plugin-astro", "prettier-plugin-tailwindcss"],
  "trailingComma": "all",
  "singleQuote": true,
  "printWidth": 80,
  "proseWrap": "never",
  "semi": true,
  "bracketSameLine": false,
  "htmlWhitespaceSensitivity": "ignore",
  "tabWidth": 2,
  "overrides": [
    {
      "files": "*.astro",
      "options": {
        "parser": "astro"
      }
    }
  ]
}
